<script>
    let modulo_caja = (function(){
        //  DIBUJO DE TABLA
        let draw            = 0;

        // Variable global para almacenar la instancia de DataTable
        let table;

        //  Rutas
        const controller    = '/Asignarbecas';
        const url_index     = controller+"/index";
        const url_cancelacion_devolucion    = controller+"/cancelarDevolverAbono";

        //  PERMISO PARA CANCELAR Y DEVOLVER PAGOS
        const cancelar_devolver_abono   = 0;

        //  language
        const translations  = {
            emptyTable: "<?= $translations['table_no_data'] ?>",
            info: "<?= $translations['showing_info'] ?>",
            infoEmpty: "<?= $translations['no_records'] ?>",
            search: "<?= $translations['search'] ?>",
            paginate: {
                first: "<?= $translations['paginate_first'] ?>",
                last: "<?= $translations['paginate_last'] ?>",
                next: "<?= $translations['paginate_next'] ?>",
                previous: "<?= $translations['paginate_previous'] ?>"
            },
            title_update    : "<?= $translations['html_edit_record'] ?>",
            title_delete    : "<?= $translations['html_delete_record'] ?>",
            title_preview   : "<?= $translations['html_preview_record'] ?>",
            title_change    : "<?= $translations['html_active_deactivate'] ?>",
            confirm_delete  : "<?= $translations['html_confirm_delete']?>",
            confirm_update  : "<?= $translations['html_confirm_update']?>",
            schedule_availability   : "<?= $translations['html_schedule_availability']?>",
            error_selected_location : "<?= $translations['error_selected_location']?>",
            error_professional      : "<?= $translations['html_error_professional']?>",
            error_selected_patient  : "<?= $translations['html_error_selected_patient']?>",
            error_starting_date     : "<?= $translations['html_error_starting_date']?>",
            appoinment_edit         : "<?= $translations['html_appoinment_edit']?>",
            cancel_appointment      : "<?= $translations['html_cancel_appointment']?>",
            register_payment        : "<?= $translations['html_register_payment']?>",
            pay                     : "<?= $translations['html_pay']?>",
            cancel_payment          : "<?= $translations['html_cancel_payment']?>",
            selected_option         : "<?= $translations['html_selected_option']?>",
            info_simultaneous_appointment   : "<?= $translations['html_info_simultaneous_appointment']?>",
        };

        //  SALDO A FAVOR DEL PACIENTE
        let saldo_favor         = 0;
        let sub_total_calculado = 0;
        let total_calculado     = 0;

        //  OBJETO CON TODOS LOS CALCULOS ALMACENADOS PARA EVITAR RECALCULO
        let obj_totales_calculados  = {
            num_citas           : 0,
            servicios           : [],
            subtotal_calculado  : 0,
            saldo_favor         : 0,
            total_pagar         : 0,
            saldo_favor_restante    : 0,
            pago_efectivo           : 0,
            pago_transferencia      : 0,
            referencia_transferencia    : '',
            fecha_transferencia         : '',
            hora_transferencia          : 0,
            pago_tarjeta                : 0,
            monto_recibido              : 0,
            excedente                   : 0,
            accion_excedente            : null
        };

        //  SE GUARDAN TODAS LAS CITAS A PAGAR Y EL SALDO ACTUAL
        let obj_citas_saldos    = [];

        //  CITAS RESULTANTES DE LA BUSQUEDA
        let obj_info_citas      = {};

        //  CITAS QUE NO APLICARA LA BECA
        let obj_citas_excluidas = [];

        // Función para inicializar o recargar la tabla
        function cargarTabla() {
            draw    ++;
            if (!table) {
                table = new DataTable('#table_results', {
                    dom: 'lrtip',
                    paging: true,
                    info: true,
                    lengthChange: false,
                    language: translations,
                    ordering: false,
                    serverSide: true,
                    ajax: {
                        url: url_index,
                        method: 'POST',
                        data: function (d) {
                            d.pageSize  = d.length == null || d.length == '' ? 1 : d.length;
                            d.offset    = d.start == null || d.start == '' ? 0 : d.start;
                            d.draw      = draw;
                            d.accion    = 'get_rows';
                            d.id_paciente   = $("#select_pacientes").val();
                            d.from_caja     = true;
                        },
                        dataSrc: function(json) {
                            $("#badge_num_abonos").text(json['recordsTotal']);
                            
                            return json.data; // IMPORTANTE retornar data
                        }
                    },
                    columns: [
                        { data: 'beca' }, // Columna 1
                        { data: 'label_fecha_captura' }, // Columna 1
                        { data: 'label_monto_asignado' }, // Columna 1
                        { data: 'label_monto_disponible' }, // Columna 1
                        {
                            data: null, 
                            className: "text-center", // Centra el contenido de la celda
                            orderable: false, // Desactiva el ordenamiento para esta columna
                            render: function (data, type, row) {
                                draw    ++;
                                let btn_preview     = ' <button class="btn btn-outline-dark btn-sm btn_preview" data-id="'+data['id']+'" title="'+translations['title_preview'] +'">' +
                                                        '   <i class="bi bi-search"></i>'+
                                                    '   </button>';

                                let btn_cancelar_devoler    = cancelar_devolver_abono ? ' <button class="btn btn-outline-dark btn-sm btn_cancelar_devolver_abono" data-id="'+data['id']+'" title="Cancelación o devolución de pago">' +
                                                                                        '   <i class="bi-arrow-counterclockwise"></i>'+
                                                                                    '   </button>' : '';

                                let btn_download    = ' <button class="btn btn-outline-dark btn-sm btn_download" data-id="'+data['id']+'" title="Descargar ticket">' +
                                                        '   <i class="bi bi-download"></i>'+
                                                    '   </button>'; 
                                return btn_preview + btn_download + btn_cancelar_devoler;
                            }
                        }
                    ],
                    createdRow: function (row, data, dataIndex) {
                        $(row).data('rowData', data);
                    }
                });
            } else {
                draw    ++;
                table.ajax.reload();
            }
        }

        $(document).ready(function(){

            $('#select_pacientes').select2({
                placeholder: translations['error_selected_patient'],
                width: '50px',
                minimumInputLength: 3,
                allowClear : false,
                ajax: {
                    url: url_index,
                    method: 'post',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        cadena_enviada  = params.term;
                        return {
                            accion: 'fill_pacientes',
                            cadena: params.term,
                            form_select2_pacientes  : true
                        };
                    },
                    processResults: function (data) {
                        // Aquí adaptamos la respuesta al formato que select2 necesita
                        return {
                            results: data.map(function (item) {
                                if (item.id == -1) return true;
                                return {
                                    id: item.id,
                                    text: item.celular + ' - ' + item.nombre_completo,
                                    nombre: item.nombre,
                                    primer_apellido: item.primer_apellido,
                                    segundo_apellido: item.segundo_apellido,
                                    celular: item.celular
                                };
                            })
                        };
                    },
                    cache: true
                }
            }).on('select2:select',function(){
                clear_view();
                ajax_get_info_paciente();
            });

            $('#select_becas').select2({
                placeholder: 'Seleccione una opción'
            }).on('select2:select',function(){
                let tipo_beca   = $("#select_becas").find('option:selected').data('tipobeca');
                tipo_beca       = tipo_beca == 1 ? '($)IMPORTE' : '(%)PORCENTAJE';

                let indefinida  = $("#select_becas").find('option:selected').data('indefinida');
                indefinida      = indefinida == 1 ? 'SI' : 'NO';

                $("#span_tipo_beca").text(tipo_beca);
                $("#span_indefinida").text(indefinida);

                $("#monto_efectivo").prop('disabled',false);
                $("#monto_transferencia").prop('disabled',false);
            });

            //  FILTRO DE BUSQUEDA DE ABONOS
            $("#btn_filtrar_tickets").on('click',function(){
                cargarTabla();
            });

            $("#btn_limpiar_filtros").on('click',function(){
                $("#filtro_folio").val('');
                $("#filtro_fecha_cita").val('');
                $("#filtro_fecha_pago").val('');
                cargarTabla();
            });

            //  EVENTOS DE TABS
            $('#tab_citas').on('click', function() {
                // Activar tab citas
                $(this).css({ 'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5' });
                $('#tab_historial').css({ 'border-bottom': '3px solid transparent', 'color': '#6c757d' });

                // Mostrar/ocultar secciones
                $('#section_citas_resumen').removeClass('d-none');
                $('#section_historial').addClass('d-none');
            });

            $('#tab_historial').on('click', function() {
                // Activar tab historial
                $(this).css({ 'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5' });
                $('#tab_citas').css({ 'border-bottom': '3px solid transparent', 'color': '#6c757d' });

                // Mostrar/ocultar secciones
                $('#section_historial').removeClass('d-none');
                $('#section_citas_resumen').addClass('d-none');
            });

            //  INPUT CHECK DE SELECCION POR CITA
            $("#body_table").on('click','.check_cita',function(){
                let check_actual    = $(this).prop('checked');
                let id_row          = $(this).closest('tr').data('idrow');
                let id_agenda_cita  = $(this).closest('tr').data('idagendacita');
                

                //  SE CAPTURAN TODAS LAS CITAS QUE VAN A QUEDAR EXCLUIDAS
                let rows        = $("#table_citas_deudoras").find('.row_cita');
                let find_check  = false;
                obj_citas_excluidas = [];
                $(rows.get().reverse()).each(function() {
                    // tu lógica aquí
                    if ($(this).find('.check_cita').is(':checked')){
                        if (!find_check){
                            find_check  = true;
                        }
                    } else {
                        if (find_check){
                            let tmp_id_agenda_cita  = $(this).data('idagendacita');
                            obj_citas_excluidas.push(tmp_id_agenda_cita);
                        }
                    }
                });

                console.log('obj_citas_excluidas',obj_citas_excluidas);
                calcula_total();
            });

            $('.input_monto_pagar').on('input', function(e, origen) {
                let val = $(this).val();

                // Si empieza con 0 seguido de otro dígito, quita el 0
                if (/^0\d/.test(val)) {
                    $(this).val(val.substring(1));
                }

                //  SI EL MONTO NO ES VALIDO SUSTITUYE POR 0
                if (!validar_monto($(this).val())) {
                    $(this).val(0);
                }

                //  VALIDACION PARA QUE PERMITA UN SOLO TIPO DE PAGO
                if ($(this).val() == '' || $(this).val() == null || $(this).val() == 0){
                    $(".input_monto_pagar").val('').prop('disabled',false);
                } else {
                    let id_input    = $(this).attr('id');
                    $('.input_monto_pagar').each(function(){
                        if (id_input != $(this).attr('id')){
                            $(this).val('');
                            $(this).prop('disabled',true);
                        } else {
                            $(this).prop('disabled',false);
                        }
                    })
                }

                const totalAPagar   = total_calculado;
                const efectivo      = parseFloat($('#monto_efectivo').val())      || 0;
                const tarjeta       = parseFloat($('#monto_tarjeta').val())       || 0;
                const transferencia = parseFloat($('#monto_transferencia').val()) || 0;

                if (transferencia > 0){
                    $("#div_referencia_transferencia").removeClass('d-none');
                } else {
                    $("#div_referencia_transferencia").addClass('d-none');
                    $("#input_referencia_transferencia").val('');
                }
                
                mostrar_monto_pagar();
            });

            //  EVENTO PARA DECIDIR QUE HACER CON EL EXCEDENTE
            $(".pay-method-btn").on('click',function(){
                $(".pay-method-btn").removeClass('active');
                $(this).addClass('active');
            });

            //  MODAL PARA MOSTRAR UN TICKET CON EL PAGO
            $("#btnProcesarPago").on('click',function(){
                //  VALIDACIONES

                if ($("#select_becas").val() == null || $("#select_becas").val() == ''){
                    showAlert('danger','Seleccione una beca');
                    return false;
                }

                if ($('#body_table input[type=checkbox]:checked').length == 0){
                    showAlert('danger','Seleccione al menos una cita');
                    return false;
                }

                //  VERIFICA QUE EXISTA UN MONTO AGREGADO
                if (($("#monto_efectivo").val() == '' || $("#monto_efectivo").val() == null) &&
                    ($("#monto_transferencia").val() == '' || $("#monto_transferencia").val() == null)) {
                        showAlert('danger','Seleccione un metodo de pago y la cantidad a liquidar');
                        return false;
                    }

                //  VALIDACIONES EN CASO DE QUE INGRESEN TRANSFERENCIA COMO METODO DE PAGO
                if ($("#monto_transferencia").val() != '' && $("#monto_transferencia").val() != null && $("#monto_transferencia").val() > 0){
                    
                    if ($("#input_referencia_transferencia").val() == null || $("#input_referencia_transferencia").val().trim() == ''){
                        showAlert('danger','Ingrese la referencia de pago');
                        return false;
                    } else {
                        if ($("#input_referencia_transferencia").val().length > 50){
                            showAlert('danger','La referencia bancaria puede tener hasta 50 caracteres');
                            return false;
                        }
                    }
                    
                    if ($("#input_fecha_transferencia").val() == null || $("#input_fecha_transferencia").val().trim() == ''){
                        showAlert('danger','Ingrese la fecha de la transferencia');
                        return false;
                    }
                }

                //  VERIFICA QUE NO SE SALTEE CITAS PARA PAGAR
                let last_checked        = 0;
                let error_check_pago    = false;

                $('#table_citas_deudoras').find(".check_cita").each(function(){
                    let num_row                 = $(this).data('numrow');
                    let id_agenda_cita          = $(this).closest('.row_cita').data('idagendacita');

                    if ($(this).prop('checked')){
                        if ((parseInt(last_checked) + parseInt(1)) == num_row){
                            last_checked    ++;
                        } else {
                            error_check_pago    = true;
                            return false;
                        }
                    } else {
                        if (obj_citas_excluidas.includes(id_agenda_cita)){
                            last_checked    ++;
                        }
                    }
                });

                if (error_check_pago){
                    showAlert('danger','Verifica la selección de citas. Debes seleccionar las citas pendientes en orden, comenzando por la más antigua.');
                    return false;
                }

                obj_totales_calculados['referencia_transferencia']  = $("#input_referencia_transferencia").val().trim();
                obj_totales_calculados['fecha_transferencia']       = $("#input_fecha_transferencia").val().trim();
                obj_totales_calculados['hora_transferencia']        = $("#input_hora_transferencia").val().trim();

