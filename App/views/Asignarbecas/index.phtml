                let total   = 0;
                $(modal_clone).find('.input_abono:checked').each(function(){
                    let row_total   = $(this).data('total');
                    total   = ((total * 100) + (row_total * 100)) / 100;
                });

                let obj_info    = {
                    arr_id_abono_movimiento     : arr_id_abono_movimiento,
                    tipo_cancelacion            : $(modal_clone).find('[name="tipo_accion"]:checked').val(),
                    observaciones_cancelacion   : $(modal_clone).find("#input_observaciones").val().trim(),
                    ticket_folio                : folio,
                    total_movimiento            : total
                }

                //const respuesta = await window.modalConfirm('Esta acción no se podra revertir ¿Deseas continuar?',true);
                const respuesta = await window.modalConfirm('Esta acción no se podra revertir ¿Deseas continuar?');

                if (respuesta){
