                } else {
                    $(btn).prop('disabled',false);
                }
            });

            $(modal_clone).find("#tbody_abonos").append(row);

            $(modal_clone).modal('show');
        }


        //  CALCULA Y RECALCULA TODAL
        function calcula_total(){
            sub_total_calculado = 0;
            total_calculado     = 0;
            
            //  RECORRIDO DE TODAS LAS CITAS SELECCIONADAS
            obj_totales_calculados['servicios'] = [];
            let citas_seleccionadas = 0;
            $("#table_citas_deudoras").find('.table-active').each(function(){
                citas_seleccionadas ++;
                let total_cita  = $(this).data('saldocita');

                let nombre_servicio = $(this).find('.td_servicio').text();

                // Si ya existe el servicio, sumar el total
                let servicio_existente = obj_totales_calculados['servicios'].find(s => s.servicio === nombre_servicio);

                if (servicio_existente) {
                    servicio_existente.total            = ((servicio_existente.total * 100) + (total_cita * 100)) / 100;
                    servicio_existente.num_servicios    = parseInt(servicio_existente.num_servicios) + parseInt(1);
                } else {
                    obj_totales_calculados['servicios'].push({
                        servicio        : nombre_servicio,
                        total           : total_cita,
                        num_servicios   : 1
                    });
                }

                sub_total_calculado = ((sub_total_calculado * 100) + (total_cita * 100)) / 100;
            });

            let mensaje = citas_seleccionadas == 1 ? 'cita' : 'citas';

            $("#span_subtotal").text('$'+formatoDinero(sub_total_calculado));
            $("#span_num_citas").text('Subtotal ('+citas_seleccionadas+' '+mensaje+')');

            //  AL SUBTOTAL SE LE RESTA EL SALDO A FAVOR
            total_calculado = ((sub_total_calculado * 100) - (saldo_favor * 100)) / 100;

            //  PARA EVITAR MOSTRAR NUMEROS NEGATIVOS
            if (total_calculado < 0){
                total_calculado = 0;
            }

            $("#span_total_a_pagar").text('$'+formatoDinero(total_calculado));

            //  SE CALCULA EL SALDO A FAVOR RESTANTE
            let saldo_favor_restante    = ((saldo_favor * 100) - (sub_total_calculado * 100)) / 100;

            if (saldo_favor_restante < 0){
                saldo_favor_restante    = 0;
            }

            //  SE GUARDA EL OBJETO
            obj_totales_calculados['num_citas'] = citas_seleccionadas;
            obj_totales_calculados['subtotal_calculado']    = sub_total_calculado;
            obj_totales_calculados['saldo_favor']           = saldo_favor;
            obj_totales_calculados['saldo_favor_restante']  = saldo_favor_restante;
            obj_totales_calculados['total_pagar']           = total_calculado;


            mostrar_monto_pagar();
        }

        //  SUMA LAS CANTIDADES ENTRE METODOS DE PAGO PARA SABER CUANDO QUIERE PAGAR EL USUARIO
        function mostrar_monto_pagar(){

            let monto_recibido  = 0;
            $(".input_monto_pagar").each(function(){
                let valor = $(this).val();
                if (valor == '' || valor == null){
                    return true;
                }
                monto_recibido = ((monto_recibido * 100) + (valor * 100)) / 100;
            });

            if (monto_recibido == 0){
               $("#btnProcesarPago").addClass('d-none');
            } else {
                $("#btnProcesarPago").removeClass('d-none');
            }

            //  SE RECORREN TODAS LAS CITAS Y SE IRAN HABILITANDO HASTA QUE EL MONTO RECIBIDO
            //  SE ACABE

            let tmp_monto_recibido  = monto_recibido;//monto_recibido != 0 ? ((monto_recibido * 100) + (saldo_favor * 100)) / 100 : 0;

            $("#body_table").find('.row_cita').each(function(){

                //  SI EXISTE LA CITA EN EL ARRAY, 
                let id_agenda_cita          = $(this).data('idagendacita');
                const existe_cita_excluida  = obj_citas_excluidas.indexOf(id_agenda_cita);
                
                //  SE DETIENE EL PROCESO SI SE ACABA EL DINERO
                if (tmp_monto_recibido > 0 && existe_cita_excluida == -1){
                    $(this).find('.check_cita').prop('disabled',false).prop('checked',true);

                    let saldo_cita          = $(this).data('saldocita');
                    let nuevo_saldo_cita    = ((saldo_cita * 100) - (tmp_monto_recibido * 100)) / 100;
                    tmp_monto_recibido      = ((tmp_monto_recibido * 100) - (saldo_cita * 100)) / 100;

                    nuevo_saldo_cita    = nuevo_saldo_cita < 0 ? 0 : nuevo_saldo_cita;

                    $(this).find('.td_saldo_cita').text('$'+formatoDinero(nuevo_saldo_cita));

                } else {
                    $(this).find('.check_cita').prop('checked',false);
                    let saldo_cita          = $(this).data('saldocita');
                    $(this).find('.td_saldo_cita').text('$'+formatoDinero(saldo_cita));
                }

                if ($(this).find('.check_cita').is(':checked')){
                    $(this).closest('tr').addClass('table-active');
                } else {
                    //  SE QUITA LA CLASE ACTIVA
                    $(this).closest('tr').removeClass('table-active');
                }

            });

            console.log('monto_recibido',monto_recibido);

            let excedente   = tmp_monto_recibido;

            // GUARDAR EN OBJETO
            obj_totales_calculados['pago_efectivo']      = $("#monto_efectivo").val();
            obj_totales_calculados['pago_transferencia'] = $("#monto_transferencia").val();
            obj_totales_calculados['pago_tarjeta']       = $("#monto_tarjeta").val();
            obj_totales_calculados['monto_recibido']     = monto_recibido;
            obj_totales_calculados['excedente']          = excedente > 0 ? excedente : 0;
            obj_totales_calculados['accion_excedente']   = 'saldo_favor';

            if (excedente > 0){
                $("#box_excedente").find("#span_excedente").text('$'+formatoDinero(excedente));
                $("#box_excedente").removeClass('d-none');
            } else {
                $("#box_excedente").find("#span_excedente").text('');
                $("#box_excedente").addClass('d-none');
            }

        }

        //  MODAL PARA CONFIRMAR EL PAGO, MUESTRA TODA LA INFORMACION
        function show_modal_confirmar_pago(fecha_hora){
            obj_totales_calculados['fecha_hora']    = fecha_hora;

            //  SE RECORRE TODAS LAS CITAS A PAGAR Y SE OBTIENE EL SALDO ACTUAL
            obj_citas_saldos    = [];
            $("#body_table").find('.table-active').each(function(){
                let id_agenda_cita  = $(this).data('idagendacita');
                let saldo_cita      = $(this).data('saldocita');
                obj_citas_saldos.push({
                    id_agenda_cita  : id_agenda_cita,
                    saldo_cita      : saldo_cita
                });
            });

            let nombre_paciente = $("#select_pacientes").find('option:selected').text();
            nombre_paciente     = nombre_paciente.split('-')[1].trim();
            let nombre_beca     = $("#select_becas").find('option:selected').text();


            let modal_clone = $("#modalConfirmarPago").clone().removeAttr('id');

            $(modal_clone).find('#ticket_fecha').text(fecha_hora);
            $(modal_clone).find('#ticket_paciente').text(nombre_paciente);
            $(modal_clone).find('#ticket_beca').text(nombre_beca);

            for(let servicio of obj_totales_calculados['servicios']){
                $(modal_clone).find('#ticket_servicios').append(`
                    <div class="d-flex justify-content-between align-items-center small">
                        <div class="d-flex align-items-center gap-2">
                            <span style="width:.5rem;height:.5rem;border-radius:50%;
                                        background:#4f46e5;flex-shrink:0;display:inline-block;"></span>
                            <span class="fw-medium">${servicio.servicio} 
                            <span class="small text-secondary">X${servicio.num_servicios}</span>
                            </span>
                        </div>
                        <span class="text-secondary">${'$'+formatoDinero(servicio.total)}</span>
                    </div>
                `);
            }

            let mensaje = obj_totales_calculados['num_citas'] == 1 ? 'cita' : 'citas';

            if (obj_totales_calculados['pago_efectivo'] > 0){
                $(modal_clone).find('.div_efectivo').removeClass('d-none').find('#ticket_efectivo').text('$'+formatoDinero(obj_totales_calculados['pago_efectivo']));
            }

            if (obj_totales_calculados['pago_tarjeta'] > 0){
                $(modal_clone).find('.div_tarjeta').removeClass('d-none').find('#ticket_tarjeta').text('$'+formatoDinero(obj_totales_calculados['pago_tarjeta']));
            }

            if (obj_totales_calculados['pago_transferencia'] > 0){
                $(modal_clone).find('.div_transferencia').removeClass('d-none').find('#ticket_transferencia').text('$'+formatoDinero(obj_totales_calculados['pago_transferencia']));
                $(modal_clone).find('.div_transferencia').find('#ticket_referencia').text(obj_totales_calculados['referencia_transferencia']);
            } else {
                $(modal_clone).find('.div_transferencia').addClass('d-none');
            }

            $(modal_clone).find("#ticket_num_citas").text('Subtotal ('+obj_totales_calculados['num_citas']+' '+mensaje+')');
            $(modal_clone).find('#ticket_subtotal').text('$'+formatoDinero(obj_totales_calculados['subtotal_calculado']));
            $(modal_clone).find('#ticket_saldo_favor').text('$'+formatoDinero(obj_totales_calculados['saldo_favor']));
            $(modal_clone).find('#ticket_saldo_favor_restante').text('$'+formatoDinero(obj_totales_calculados['saldo_favor_restante']));
            $(modal_clone).find('#ticket_total').text('$'+formatoDinero(obj_totales_calculados['total_pagar']));
            $(modal_clone).find('#ticket_monto_recibido').text('$'+formatoDinero(obj_totales_calculados['monto_recibido']));

            console.log('excedente objeto',obj_totales_calculados['excedente']);
            if (obj_totales_calculados['excedente'] > 0){
                $(modal_clone).find('#ticket_box_excedente').removeClass('d-none').find('#ticket_excedente_monto').text('$'+formatoDinero(obj_totales_calculados['excedente']));
                $(modal_clone).find('#ticket_excedente_label').text(obj_totales_calculados['accion_excedente'] == 'saldo_favor' ? 'Saldo a favor' : 'Devolver cambio');
            }

            $(modal_clone).on('click','#btn_confirmar_pago',function(){
                let btn = $(this);
                $(btn).prop('disabled',true);

                console.log('obj_citas_excluidas',$("#select_becas").val());

                let obj_info_pago = {
                    pago_efectivo       : parseFloat(obj_totales_calculados['pago_efectivo']) || 0,
                    pago_transferencia  : parseFloat(obj_totales_calculados['pago_transferencia']) || 0,
                    pago_tarjeta        : parseFloat(obj_totales_calculados['pago_tarjeta']) || 0,
                    referencia_transferencia    : obj_totales_calculados['referencia_transferencia'] || '',
                    fecha_transferencia         : obj_totales_calculados['fecha_transferencia'] || '',
                    hora_transferencia          : obj_totales_calculados['hora_transferencia'] || '',
                    excedente                   : parseFloat(obj_totales_calculados['excedente']) || 0,
                    accion_excedente            : obj_totales_calculados['accion_excedente'] || '',
                    saldo_favor                 : saldo_favor,
                    saldo_favor_restante        : parseFloat(obj_totales_calculados['saldo_favor_restante']) || 0,
                    id_beca                     : $("#select_becas").val(),
                    nombre_beca                 : $("#select_becas").find('option:selected').val(),
                    citas_excluidas             : obj_citas_excluidas != [] ? obj_citas_excluidas : null
                };

                // Aplicar resta si es devolver cambio
                if (obj_info_pago['accion_excedente'] === 'devolver_cambio') {
                    obj_info_pago['pago_efectivo']  = ((obj_info_pago['pago_efectivo'] * 100) - (obj_info_pago['excedente']    * 100)) / 100;
                    obj_info_pago['excedente']      = 0;
                }

                console.log('obj_info_pago',obj_info_pago);

                $.ajax({
                    url         : url_index,
                    method      : 'post',
                    dataType    : 'json',
                    data        : {
                        accion              : 'save_pago',
                        obj_citas_saldos    : obj_citas_saldos,
                        obj_info_pago       : obj_info_pago,
                        info_ticket         : obj_totales_calculados,
                        id_paciente         : $("#select_pacientes").val(),
                        nombre_paciente     : nombre_paciente
                    },
                    success     : function(data){
                        showAlert("success",'Captura Exitosa!');
                        $(modal_clone).modal('hide');
                        clear_view();
                        ajax_get_info_paciente();
                    },
                    error       : function(error){
                        actionJsonError(error,btn);
                    }
                })
            });

            $(modal_clone).modal('show');
        }

        //  MODAL PARA CONFIRMAR EL PAGO, MUESTRA TODA LA INFORMACION
        function show_modal_preview_ticket(detalle,nombre_paciente){

            let modal_clone = $("#modalConfirmarPago").clone().removeAttr('id');

            $(modal_clone).find('#label_verifica_datos').text('');
            $(modal_clone).find('#btn_confirmar_pago').remove();
            $(modal_clone).find('#close_modal').text('Cerrar');

            $(modal_clone).find('#modalConfirmarPagoLabel').text('¡Pago realizado!');

            $(modal_clone).find("#ticket_folio").text(detalle['folio'])
            $(modal_clone).find('#ticket_fecha').text(detalle['fecha_hora']);
            $(modal_clone).find('#ticket_paciente').text(nombre_paciente);
            $(modal_clone).find('#ticket_beca').text(detalle['nombre_beca']);

            for(let servicio of detalle['servicios']){
                $(modal_clone).find('#ticket_servicios').append(`
                    <div class="d-flex justify-content-between align-items-center small">
                        <div class="d-flex align-items-center gap-2">
                            <span style="width:.5rem;height:.5rem;border-radius:50%;
                                        background:#4f46e5;flex-shrink:0;display:inline-block;"></span>
                            <span class="fw-medium">${servicio.servicio} 
                            <span class="small text-secondary">X${servicio.num_servicios}</span>
                            </span>
                        </div>
                        <span class="text-secondary">${'$'+formatoDinero(servicio.total)}</span>
                    </div>
                `);
            }

            let mensaje = detalle['num_citas'] == 1 ? 'cita' : 'citas';

            if (detalle['pago_efectivo'] > 0){
                $(modal_clone).find('.div_efectivo').removeClass('d-none').find('#ticket_efectivo').text('$'+formatoDinero(detalle['pago_efectivo']));
            }

            if (detalle['pago_tarjeta'] > 0){
                $(modal_clone).find('.div_tarjeta').removeClass('d-none').find('#ticket_tarjeta').text('$'+formatoDinero(detalle['pago_tarjeta']));
            }

            console.log('detalle',detalle['pago_transferencia']);
            if (detalle['pago_transferencia'] != '' && detalle['pago_transferencia'] > 0){
                console.log('aqui');
                $(modal_clone).find('.div_transferencia').removeClass('d-none').find('#ticket_transferencia').text('$'+formatoDinero(detalle['pago_transferencia']));
                $(modal_clone).find('.div_transferencia').find('#ticket_referencia').text(detalle['referencia_transferencia']);
            }

            $(modal_clone).find("#ticket_num_citas").text('Subtotal ('+detalle['num_citas']+' '+mensaje+')');
            $(modal_clone).find('#ticket_subtotal').text('$'+formatoDinero(detalle['subtotal_calculado']));
            $(modal_clone).find('#ticket_saldo_favor').text('$'+formatoDinero(detalle['saldo_favor']));
            $(modal_clone).find('#ticket_total').text('$'+formatoDinero(detalle['total_pagar']));
            $(modal_clone).find('#ticket_monto_recibido').text('$'+formatoDinero(detalle['monto_recibido']));

            if (detalle['excedente'] > 0){
                $(modal_clone).find('#ticket_box_excedente').removeClass('d-none').find('#ticket_excedente_monto').text('$'+formatoDinero(detalle['excedente']));
                $(modal_clone).find('#ticket_excedente_label').text(detalle['accion_excedente'] == 'saldo_favor' ? 'Saldo a favor' : 'Devolver cambio');
            }

            $(modal_clone).modal('show');
        }

        //  FUNCION PARA LIMPIAR TODO LO VISUAL
        function clear_view(){
            
            $("#body_table").find('.row_cita').remove();
            $("#body_table").find('#row_sin_registros').show();
            $("#span_saldo_favor").text('-$0.00');

            //  BECA
            $("#select_becas").prop('disabled',true).val(null).trigger('change');
            $("#span_tipo_beca").text('-');
            $("#span_indefinida").text('-');

            $(".input_monto_pagar").prop('disabled',true).val('');
            $("#btnProcesarPago").addClass('d-none');


            //  SALDO A FAVOR DEL PACIENTE
            saldo_favor         = 0;
            sub_total_calculado = 0;
            total_calculado     = 0;

            //  OBJETO CON TODOS LOS CALCULOS ALMACENADOS PARA EVITAR RECALCULO
            obj_totales_calculados  = {
                num_citas           : 0,
                servicios           : [],
                subtotal_calculado  : 0,
                saldo_favor         : 0,
                total_pagar         : 0,
                saldo_favor_restante    : 0,
                pago_efectivo           : 0,
                pago_transferencia      : 0,
                referencia_transferencia    : '',
                fecha_transferencia         : '',
                hora_transferencia          : 0,
                pago_tarjeta                : 0,
                monto_recibido              : 0,
                excedente                   : 0,
                accion_excedente            : null
            };

            //  SE GUARDAN TODAS LAS CITAS A PAGAR Y EL SALDO ACTUAL
            obj_citas_saldos    = [];

            //  LIMPIA DE COUNTS
            $("#badge_num_citas").text(0);
            $("#badge_num_abonos").text(0);

            //  BLOQUEO DE FILTROS DE BUSQUEDA DE TICKETS
            $(".filtros_ticket").prop('disabled',true);

            if (table != undefined){
                draw    ++;
                table.ajax.reload();
            }

            //  LIMPIA DE TRANSFERENCIAS
            $("#input_referencia_transferencia").val('');
            $("#input_fecha_transferencia").val('');
            $("#input_hora_transferencia").val('');
            $("#div_referencia_transferencia").addClass('d-none');
            
            
        }
    })();
</script>