                    '<tr class="row_cita row_'+num_citas+'" data-idrow="'+num_citas+'" data-saldocita="'+cita.saldo_cita+'" data-idagendacita="'+cita.id_agenda_cita+'">'+
                        '<td><input class="check_cita" type="checkbox" '+disabled+' /></td>'+
                        '<td class="small">'+num_citas+'</td>'+
                        '<td class="small">'+cita.nombre_profesional+'</td>'+
                        '<td class="small td_servicio">'+cita.num_servicios_costo+'</td>'+
                        '<td class="small">$'+formatoDinero(cita.saldo_cita)+'</td>'+
                        '<td class="small">'+cita.fecha_completa+'</td>'+
                        '<td><span class="badge rounded-pill badge-'+cita.asistencia+' px-2 py-1 small fw-semibold">'+cita.label_asistencia+'</span></td>'+
                        '<td><span class="badge rounded-pill badge-cita-'+cita.activa+' px-2 py-1 small fw-semibold">'+cita.estatus+'</span></td>'+
                    '</tr>';

                    $("#body_table").append(row);
                }
            }
            
        }

        //  CALCULA Y RECALCULA TODAL
        function calcula_total(){
            sub_total_calculado = 0;
            total_calculado     = 0;
            
            //  RECORRIDO DE TODAS LAS CITAS SELECCIONADAS
            obj_totales_calculados['servicios'] = [];
            let citas_seleccionadas = 0;
            $("#body_table").find('.table-active').each(function(){
                citas_seleccionadas ++;
                let total_cita  = $(this).data('saldocita');

                let nombre_servicio = $(this).find('.td_servicio').text();

                // Si ya existe el servicio, sumar el total
                let servicio_existente = obj_totales_calculados['servicios'].find(s => s.servicio === nombre_servicio);

                if (servicio_existente) {
                    servicio_existente.total            = ((servicio_existente.total * 100) + (total_cita * 100)) / 100;
                    servicio_existente.num_servicios    = parseInt(servicio_existente.num_servicios) + parseInt(1);
                } else {
                    obj_totales_calculados['servicios'].push({
                        servicio        : nombre_servicio,
                        total           : total_cita,
                        num_servicios   : 1
                    });
                }

                sub_total_calculado = ((sub_total_calculado * 100) + (total_cita * 100)) / 100;
            });

            let mensaje = citas_seleccionadas == 1 ? 'cita' : 'citas';

            $("#span_subtotal").text('$'+formatoDinero(sub_total_calculado));
            $("#span_num_citas").text('Subtotal ('+citas_seleccionadas+' '+mensaje+')');

            //  AL SUBTOTAL SE LE RESTA EL SALDO A FAVOR
            total_calculado = ((sub_total_calculado * 100) - (saldo_favor * 100)) / 100;

            //  PARA EVITAR MOSTRAR NUMEROS NEGATIVOS
            if (total_calculado < 0){
                total_calculado = 0;
            }

            $("#span_total_a_pagar").text('$'+formatoDinero(total_calculado));

            //  SE VUELVE DISABLED EL INPUT SI NO HAY CITAS SELECCIONADAS
            $(".input_monto_pagar").prop('disabled',citas_seleccionadas <= 0);

            if (citas_seleccionadas == 0){
               $(".input_monto_pagar").val('');
               $("#btnProcesarPago").addClass('d-none');
            } else {
                $("#btnProcesarPago").removeClass('d-none');
            }

            //  SE GUARDA EL OBJETO
            obj_totales_calculados['num_citas'] = citas_seleccionadas;
            obj_totales_calculados['subtotal_calculado']    = sub_total_calculado;
            obj_totales_calculados['saldo_favor']   = saldo_favor;
            obj_totales_calculados['total_pagar']   = total_calculado;


            mostrar_monto_pagar();
        }

        //  SUMA LAS CANTIDADES ENTRE METODOS DE PAGO PARA SABER CUANDO QUIERE PAGAR EL USUARIO
        function mostrar_monto_pagar(){
            let monto_recibido  = 0;
            $(".input_monto_pagar").each(function(){
                let valor = $(this).val();
                if (valor == '' || valor == null){
                    return true;
                }
                monto_recibido = ((monto_recibido * 100) + (valor * 100)) / 100;
            });

            // MUESTRA EL MONTO FALTANTE
            let monto_faltante = ((total_calculado * 100) - (monto_recibido * 100)) / 100;
            monto_faltante     = monto_faltante > 0 ? monto_faltante : 0;
            $("#span_monto_faltante").text("$" + formatoDinero(monto_faltante));
            $("#span_monto_recibido").text("$" + formatoDinero(monto_recibido));

            // CITAS DISPONIBLES PARA SELECCIONAR
            const citas_disponibles = $('#body_table input[type=checkbox]:not(:checked)').length > 0;
            const excedente         = (((monto_recibido * 100) - (total_calculado * 100)) / 100);

            // HAY EFECTIVO?
            const tiene_efectivo = parseFloat($("#monto_efectivo").val()) > 0;

            // CAMBIA EL COLOR DEPENDIENDO DEL MONTO
            $('#box_monto_recibido').removeClass('completo excedido incompleto');

            switch (true) {
                case monto_recibido === 0:
                    $('#box_excedente').addClass('d-none');
                    break;

                case monto_recibido === total_calculado:
                    $('#box_monto_recibido').addClass('completo');
                    $('#box_excedente').addClass('d-none');
                    break;

                case excedente > 0:
                    $('#box_monto_recibido').addClass('excedido');
                    $('#span_excedente').text('$' + formatoDinero(excedente));
                    $('#box_excedente').removeClass('d-none');
                    $(".pay-method-btn").removeClass('active');

                    // "Devolver Cambio" solo si hay efectivo
                    if (tiene_efectivo) {
                        $('#btn_devolver_cambio').removeClass('d-none');
                        $('#btn_devolver_cambio').addClass('active'); // accion por defecto
                    } else {
                        $('#btn_devolver_cambio').addClass('d-none');
                    }

                    // "Saldo a Favor" solo si no hay citas pendientes
                    if (citas_disponibles && tiene_efectivo) {
                        $('#btn_saldo_favor').addClass('d-none');
                    } else {
                        $('#btn_saldo_favor').removeClass('d-none');
                    }

                    // Si no hay efectivo, saldo a favor es la accion por defecto
                    if (!tiene_efectivo) {
                        $('#btn_saldo_favor').addClass('active');
                    }

                    break;

                default:
                    $('#box_monto_recibido').addClass('incompleto');
                    $('#box_excedente').addClass('d-none');
                    break;
            }

            // GUARDAR EN OBJETO
            obj_totales_calculados['pago_efectivo']      = $("#monto_efectivo").val();
            obj_totales_calculados['pago_transferencia'] = $("#monto_transferencia").val();
            obj_totales_calculados['pago_tarjeta']       = $("#monto_tarjeta").val();
            obj_totales_calculados['monto_recibido']     = monto_recibido;
            obj_totales_calculados['excedente']          = excedente > 0 ? excedente : 0;
            obj_totales_calculados['accion_excedente']   = $('#btn_saldo_favor').hasClass('active') 
                                                            ? 'saldo_favor' 
                                                            : 'devolver_cambio';
        }

        //  MODAL PARA CONFIRMAR EL PAGO, MUESTRA TODA LA INFORMACION
        function show_modal_confirmar_pago(fecha_hora){
            obj_totales_calculados['fecha_hora']    = fecha_hora;

            //  SE RECORRE TODAS LAS CITAS A PAGAR Y SE OBTIENE EL SALDO ACTUAL
            obj_citas_saldos    = [];
            $("#body_table").find('.table-active').each(function(){
                let id_agenda_cita  = $(this).data('idagendacita');
                let saldo_cita      = $(this).data('saldocita');
                obj_citas_saldos.push({
                    id_agenda_cita  : id_agenda_cita,
                    saldo_cita      : saldo_cita
                });
            });

            console.log('obj_totales_calculados');
            console.log(obj_totales_calculados);
            console.log('obj_citas_saldos');
            console.log(obj_citas_saldos);
            let nombre_paciente = $("#select_pacientes").find('option:selected').text();
            nombre_paciente     = nombre_paciente.split('-')[1].trim();

            let modal_clone = $("#modalConfirmarPago").clone().removeAttr('id');

            $(modal_clone).find('#ticket_fecha').text(fecha_hora);
            $(modal_clone).find('#ticket_paciente').text(nombre_paciente);

            for(let servicio of obj_totales_calculados['servicios']){
                $(modal_clone).find('#ticket_servicios').append(`
                    <div class="d-flex justify-content-between align-items-center small">
                        <div class="d-flex align-items-center gap-2">
                            <span style="width:.5rem;height:.5rem;border-radius:50%;
                                        background:#4f46e5;flex-shrink:0;display:inline-block;"></span>
                            <span class="fw-medium">${servicio.servicio} 
                            <span class="small text-secondary">X${servicio.num_servicios}</span>
                            </span>
                        </div>
                        <span class="text-secondary">${'$'+formatoDinero(servicio.total)}</span>
                    </div>
                `);
            }

            let mensaje = obj_totales_calculados['num_citas'] == 1 ? 'cita' : 'citas';

            if (obj_totales_calculados['pago_efectivo'] > 0){
                $(modal_clone).find('.div_efectivo').removeClass('d-none').find('#ticket_efectivo').text('$'+formatoDinero(obj_totales_calculados['pago_efectivo']));
            }

            if (obj_totales_calculados['pago_tarjeta'] > 0){
                $(modal_clone).find('.div_tarjeta').removeClass('d-none').find('#ticket_tarjeta').text('$'+formatoDinero(obj_totales_calculados['pago_tarjeta']));
            }

            if (obj_totales_calculados['pago_transferencia'] > 0){
                $(modal_clone).find('.div_transferencia').removeClass('d-none').find('#ticket_transferencia').text('$'+formatoDinero(obj_totales_calculados['pago_transferencia']));
            }

            $(modal_clone).find("#ticket_num_citas").text('Subtotal ('+obj_totales_calculados['num_citas']+' '+mensaje+')');
            $(modal_clone).find('#ticket_subtotal').text('$'+formatoDinero(obj_totales_calculados['subtotal_calculado']));
            $(modal_clone).find('#ticket_saldo_favor').text('$'+formatoDinero(obj_totales_calculados['saldo_favor']));
            $(modal_clone).find('#ticket_total').text('$'+formatoDinero(obj_totales_calculados['total_pagar']));
            $(modal_clone).find('#ticket_monto_recibido').text('$'+formatoDinero(obj_totales_calculados['monto_recibido']));

            if (obj_totales_calculados['excedente'] > 0){
                $(modal_clone).find('#ticket_box_excedente').removeClass('d-none').find('#ticket_excedente_monto').text('$'+formatoDinero(obj_totales_calculados['excedente']));
                $(modal_clone).find('#ticket_excedente_label').text(obj_totales_calculados['accion_excedente'] == 'saldo_favor' ? 'Saldo a favor' : 'Devolver cambio');
            }

            $(modal_clone).on('click','#btn_confirmar_pago',function(){
                let btn = $(this);
                $(btn).prop('disabled',true);

                let obj_info_pago = {
                    pago_efectivo       : parseFloat(obj_totales_calculados['pago_efectivo']) || 0,
                    pago_transferencia  : parseFloat(obj_totales_calculados['pago_transferencia']) || 0,
                    pago_tarjeta        : parseFloat(obj_totales_calculados['pago_tarjeta']) || 0,
                    excedente           : parseFloat(obj_totales_calculados['excedente']) || 0,
                    accion_excedente    : obj_totales_calculados['accion_excedente'] || '',
                    saldo_favor         : saldo_favor
                };

                // Aplicar resta si es devolver cambio
                if (obj_info_pago['accion_excedente'] === 'devolver_cambio') {
                    obj_info_pago['pago_efectivo']  = ((obj_info_pago['pago_efectivo'] * 100) - (obj_info_pago['excedente']    * 100)) / 100;
                    obj_info_pago['excedente']      = 0;
                }

                $.ajax({
                    url         : url_index,
                    method      : 'post',
                    dataType    : 'json',
                    data        : {
                        accion              : 'save_pago',
                        obj_citas_saldos    : obj_citas_saldos,
                        obj_info_pago       : obj_info_pago,
                        info_ticket         : obj_totales_calculados,
                        id_paciente         : $("#select_pacientes").val(),
                        nombre_paciente     : nombre_paciente
                    },
                    success     : function(data){
                        console.log('data');
                        console.log(data);
                    },
                    error       : function(error){
                        actionJsonError(error,btn);
                    }
                })
            });

            $(modal_clone).modal('show');
        }
    })();
</script>