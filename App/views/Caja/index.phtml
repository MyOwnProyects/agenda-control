        //  Rutas
        const controller    = '/Caja';
        const url_index     = controller+"/index";

        //  language
        const translations  = {
            emptyTable: "<?= $translations['table_no_data'] ?>",
            info: "<?= $translations['showing_info'] ?>",
            infoEmpty: "<?= $translations['no_records'] ?>",
            search: "<?= $translations['search'] ?>",
            paginate: {
                first: "<?= $translations['paginate_first'] ?>",
                last: "<?= $translations['paginate_last'] ?>",
                next: "<?= $translations['paginate_next'] ?>",
                previous: "<?= $translations['paginate_previous'] ?>"
            },
            title_update    : "<?= $translations['html_edit_record'] ?>",
            title_delete    : "<?= $translations['html_delete_record'] ?>",
            title_preview   : "<?= $translations['html_preview_record'] ?>",
            title_change    : "<?= $translations['html_active_deactivate'] ?>",
            confirm_delete  : "<?= $translations['html_confirm_delete']?>",
            confirm_update  : "<?= $translations['html_confirm_update']?>",
            schedule_availability   : "<?= $translations['html_schedule_availability']?>",
            error_selected_location : "<?= $translations['error_selected_location']?>",
            error_professional      : "<?= $translations['html_error_professional']?>",
            error_selected_patient  : "<?= $translations['html_error_selected_patient']?>",
            error_starting_date     : "<?= $translations['html_error_starting_date']?>",
            appoinment_edit         : "<?= $translations['html_appoinment_edit']?>",
            cancel_appointment      : "<?= $translations['html_cancel_appointment']?>",
            register_payment        : "<?= $translations['html_register_payment']?>",
            pay                     : "<?= $translations['html_pay']?>",
            cancel_payment          : "<?= $translations['html_cancel_payment']?>",
            selected_option         : "<?= $translations['html_selected_option']?>",
            info_simultaneous_appointment   : "<?= $translations['html_info_simultaneous_appointment']?>",
        };

        //  SALDO A FAVOR DEL PACIENTE
        let saldo_favor         = 0;
        let sub_total_calculado = 0;
        let total_calculado     = 0;

        //  OBJETO CON TODOS LOS CALCULOS ALMACENADOS PARA EVITAR RECALCULO
        let obj_totales_calculados  = {
            num_citas           : 0,
            servicios           : [],
            subtotal_calculado  : 0,
            saldo_favor         : 0,
            total_pagar         : 0,
            pago_efectivo       : 0,
            pago_transferencia  : 0,
            pago_tarjeta        : 0,
            monto_recibido      : 0,
            excedente           : 0,
            accion_excedente    : null
        };

        //  SE GUARDAN TODAS LAS CITAS A PAGAR Y EL SALDO ACTUAL
        let obj_citas_saldos    = [];

        // Función para inicializar o recargar la tabla
        function cargarTabla() {
            
            draw    ++;
            if (!table) {
                table = new DataTable('#table_results', {
                    dom: 'lrtip',
                    paging: true,
                    info: true,
                    lengthChange: false,
                    language: translations,
                    ordering: false,
                    serverSide: true,
                    ajax: {
                        url: url_index,
                        method: 'POST',
                        data: function (d) {
                            d.pageSize  = d.length == null || d.length == '' ? 1 : d.length;
                            d.offset    = d.start == null || d.start == '' ? 0 : d.start;
                            d.draw      = draw;
                            d.accion    = 'get_rows';
                            d.folio     = '';
                            d.id_paciente   = $("#select_pacientes").val();
                        }
                    },
                    columns: [
                        { data: 'folio' }, // Columna 1
                        { data: 'nombre_usuario' }, // Columna 1
                        { data: 'label_fecha' }, // Columna 1
                        { data: 'total_pagar' }, // Columna 1
                        {
                            data: null, 
                            className: "text-center", // Centra el contenido de la celda
                            orderable: false, // Desactiva el ordenamiento para esta columna
                            render: function (data, type, row) {
                                draw    ++;
                                return '';
                            }
                        }
                    ],
                    createdRow: function (row, data, dataIndex) {
                        
                    }
                });
            } else {
                draw    ++;
                table.ajax.reload();
            }
        }

        $(document).ready(function(){

            $('#select_pacientes').select2({
                placeholder: translations['error_selected_patient'],
                width: '50px',
                minimumInputLength: 3,
                allowClear : false,
                ajax: {
                    url: url_index,
                    method: 'post',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        cadena_enviada  = params.term;
                        return {
                            accion: 'fill_pacientes',
                            cadena: params.term,
                            form_select2_pacientes  : true
                        };
                    },
                    processResults: function (data) {
                        // Aquí adaptamos la respuesta al formato que select2 necesita
                        return {
                            results: data.map(function (item) {
                                if (item.id == -1) return true;
                                return {
                                    id: item.id,
                                    text: item.celular + ' - ' + item.nombre_completo,
                                    nombre: item.nombre,
                                    primer_apellido: item.primer_apellido,
                                    segundo_apellido: item.segundo_apellido,
                                    celular: item.celular
                                };
                            })
                        };
                    },
                    cache: true
                }
            }).on('select2:select',function(){
                $.ajax({
                    url         : url_index,
                    method      : 'post',
                    dataType    : 'json' ,
                    data        : {
                        accion      : 'get_citas_adeudos',
                        id_paciente : $("#select_pacientes").val()
                    },
                    success     : function(data){
                        show_table_citas(data);
                        cargarTabla();
                    },
                    error       : function(error){
                        console.log('data');
                        console.log(data);
                    }
                })
            });

            //  EVENTOS DE TABS
            $('#tab_citas').on('click', function() {
                // Activar tab citas
                $(this).css({ 'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5' });
                $('#tab_historial').css({ 'border-bottom': '3px solid transparent', 'color': '#6c757d' });

                // Mostrar/ocultar secciones
                $('#section_citas_resumen').removeClass('d-none');
                $('#section_historial').addClass('d-none');
            });

            $('#tab_historial').on('click', function() {
                // Activar tab historial
                $(this).css({ 'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5' });
                $('#tab_citas').css({ 'border-bottom': '3px solid transparent', 'color': '#6c757d' });

                // Mostrar/ocultar secciones
                $('#section_historial').removeClass('d-none');
                $('#section_citas_resumen').addClass('d-none');
            });

            //  INPUT CHECK SELECCION DE TODAS LAS CITAS
            $("#check_todas_citas").on('click',function(){
                let check_actual    = $(this).prop('checked');

                $("#body_table").find('.check_cita').each(function(){
                    if (check_actual){
                        $(this).closest('tr').addClass('table-active');
                        $(this).prop('disabled',false).prop('checked',true);
                    } else {
                        $(this).closest('tr').removeClass('table-active');
                        $(this).prop('checked',false);

                        //  DEJA HABILITADO EL PRIMER ROW
                        if ($(this).closest('tr').data('idrow') != 1){
                            $(this).prop('disabled',true);
                        }
                    }
                });
                
                calcula_total();
            });

            //  INPUT CHECK DE SELECCION POR CITA
            $("#body_table").on('click','.check_cita',function(){
                let check_actual    = $(this).prop('checked');
                let id_row          = $(this).closest('tr').data('idrow');
                if (check_actual){
                    $(this).closest('tr').addClass('table-active');
                    
                    //  SE DESBLOQUEA EL SIGUIENTE ROW
                    let next_row    = parseInt(id_row) + parseInt(1);
                    $("#body_table").find('.row_'+next_row).find('.check_cita').prop('disabled',false);

                    //  SI TODAS LAS CITAS ESTAN SELECCIONADAS SE SELECCIONA EL DIV GENERAL
                    const citas_no_marcadas = $('#body_table input[type=checkbox]:not(:checked)').length > 0;
                    
                    if (!citas_no_marcadas){
                        $("#check_todas_citas").prop('checked',true);
                    }

                } else {

                    //  SE QUITA LA CLASE ACTIVA
                    $(this).closest('tr').removeClass('table-active');

                    //  SE DSELECCIONAN Y SE BLOQUEAN TODOS LOS ROWS SIGUIENTES A ESTE
                    $("#body_table").find('.row_cita').each(function(){
                        if ($(this).data('idrow') > id_row){
                            $(this).removeClass('table-active');
                            $(this).find('.check_cita').prop('disabled',true).prop('checked',false);
                        }
                    });

                    $("#check_todas_citas").prop('checked',false);
                }
                calcula_total();
            });

            $('.input_monto_pagar').on('input', function(e, origen) {
                $(this).val($(this).val().replace(/[^0-9.]/g, ''));

                const totalAPagar   = total_calculado;
                const efectivo      = parseFloat($('#monto_efectivo').val())      || 0;
                const tarjeta       = parseFloat($('#monto_tarjeta').val())       || 0;
                const transferencia = parseFloat($('#monto_transferencia').val()) || 0;

                // Bloquear otros métodos solo si UN método ya supera el total individualmente
                if (efectivo >= totalAPagar) {
                    $('#monto_tarjeta, #monto_transferencia').val('').prop('disabled', true);
                } else if (tarjeta >= totalAPagar) {
                    $('#monto_efectivo, #monto_transferencia').val('').prop('disabled', true);
                } else if (transferencia >= totalAPagar) {
                    $('#monto_efectivo, #monto_tarjeta').val('').prop('disabled', true);
                } else {
                    // Ninguno supera el total solo, habilitar todos
                    $('#monto_efectivo, #monto_tarjeta, #monto_transferencia').prop('disabled', false);
                }
                
                mostrar_monto_pagar();
            });

            //  EVENTO PARA DECIDIR QUE HACER CON EL EXCEDENTE
            $(".pay-method-btn").on('click',function(){
                $(".pay-method-btn").removeClass('active');
                $(this).addClass('active');
            });

            //  MODAL PARA MOSTRAR UN TICKET CON EL PAGO
            $("#btnProcesarPago").on('click',function(){
                //  VALIDACIONES
                if ($('#body_table input[type=checkbox]:checked').length == 0){
                    showAlert('danger','Seleccione al menos una cita');
                    return false;
                }

                //  VERIFICA QUE EXISTA UN MONTO AGREGADO
                if (($("#monto_efectivo").val() == '' || $("#monto_efectivo").val() == null) &&
                    ($("#monto_transferencia").val() == '' || $("#monto_transferencia").val() == null)) {
                        showAlert('danger','Seleccione un metodo de pago y la cantidad a liquidar');
                        return false;
                    }

                if (obj_totales_calculados['excedente'] > 0 && $(".pay-method-btn.active").length == 0){
                    showAlert('danger','Seleccione la acción sobre el monto excedente');
                    return false;
                }

                if (obj_totales_calculados['excedente'] > 0){
                    obj_totales_calculados['accion_excedente']  = $(".pay-method-btn.active").data('excedente');
                } else {
                    obj_totales_calculados['accion_excedente']  = null;
                }

                //  VERIFICAR SI TODOS LOS INPUT DE FORMA DE PAGO GENERAR SALDO A FAVOR
                let input_con_valor         = 0;
                let input_con_saldo_favor   = 0;
                $(".input_monto_pagar").each(function(){
                    if ($(this).val() != null && $(this).val() != ''){
                        input_con_valor ++;
                        let valor       = parseFloat($(this).val());
                        let total_pagar = parseFloat(obj_totales_calculados['total_pagar']);
                        if (valor > total_pagar){
                            input_con_saldo_favor    ++;
                        }
                    }
                });

                if (input_con_saldo_favor > 1){
                    showAlert("danger","No puede haber mas de un metodo de pago que genere saldo a favor");
                    return false;
                }

                $.ajax({
                    url         : url_index,
                    method      : 'post',
                    dataType    : 'json',
                    data        : {
                        accion  : 'get_fecha_hora'
                    },
                    success     : function(data){
                        show_modal_confirmar_pago(data['fecha_hora']);

                    },
                    error       : function(error){
                        show_modal_confirmar_pago(moment().format('DD/MM/YYYY HH:mm'));
                    }
                })
                
            });
        });

        //  
        function show_table_citas(info_paciente){

            let info_citas  = info_paciente['citas'];
            saldo_favor     = info_paciente['saldo_favor'];

            //  SE MUESTRA EL SALDO A FAVOR
            $("#span_saldo_favor").text('-$'+formatoDinero(saldo_favor));

            if (Object.keys(info_citas).length == 0){
                $("#row_sin_registros").show();
            } else {
                $("#row_sin_registros").hide();
