<script>
    var modulo_plantillas_mensaje = (function(){

        //  INFORMACION DE LA LOCACION PARA MOSTRAR EN VISTA PREVIA
        let nombre_locacion     = '<?php echo $nombre_locacion; ?>';
        let latitud_locacion    = '<?php echo $latitud_locacion; ?>';
        let longitud_locacion   = '<?php echo $longitud_locacion; ?>';

        //  INFORMACION DE LA PLANTILLA
        let tmp_obj_plantillas  = '<?php echo $json_plantillas; ?>';
        tmp_obj_plantillas      = JSON.parse(tmp_obj_plantillas);

        //  URL
        const controller    = '/Plantillasmensajes';
        const url_index     = controller+"/index";
        const url_save      = controller+"/save";
        const url_delete    = controller+"/delete";


        let obj_plantillas_originales   = {
            0   : {
                activa  : 1,
                clave   : '',
                id      : null,
                mensaje : '',
                nombre  : '',
                tipo_mensaje    : ''
            }
        };

        let obj_plantillas_finales  = {
            0   : {
                activa  : 1,
                clave   : '',
                id      : null,
                mensaje : '',
                nombre  : '',
                tipo_mensaje    : ''
            }
        };

        //  SE CREAN LOS OBJETOS PARA TENER UNO CON LA INFORMACION ORIGINAL 
        //  Y UN SEGUNDO CON LA INFORMACION EDITADA PARA GUARDAR
        tmp_obj_plantillas.forEach(function(plantilla) {
            obj_plantillas_originales[plantilla.id] = JSON.parse(JSON.stringify(plantilla));
            obj_plantillas_finales[plantilla.id]    = JSON.parse(JSON.stringify(plantilla));
        });

        let count_id_plantilla  = 0;
        let mensaje_visto_html  = `
                                    <div class="wa-bubble-meta">
                                        <span>14:20 PM</span>
                                        <i class="bi bi-check2-all"></i>
                                    </div>
                                `;
        const limite_caracteres = 1024;

        $(document).ready(function(){

            $(".template-list").on('click','.template-item',function(){
                guardar_cambios_plantila($(".template-list").find('.active').data('id'));
                let btn = $(this);

                //  SLEEP PARA GARANTIZAR QUE EL OBJETO GUARDARA LA INFORMACION ACTUAL
                setTimeout(function() {

                    $(".template-list").find('.active').removeClass('active');
                    $(btn).addClass('active');

                    if ($(".template-list").find('.active').attr('id') != 'plantilla_0'){
                        $("#btnDelete").show();
                    } else {
                        $("#btnDelete").hide();
                    }

                    show_info_plantilla();
                }, 150);
            });

            //  EVENTO PARA LIMITAR LOS CARACTERES Y MOSTRAR EL PREVIEW
            $("#textarea_mensaje").on('keydown', function(e) {
                let mensaje = $(this).val().trim();

                // Si ya llegó al límite, solo permite teclas de control
                if (mensaje.length >= limite_caracteres) {
                    let teclasPermitidas = [
                        'Backspace', 'Delete', 'ArrowLeft', 'ArrowRight',
                        'ArrowUp', 'ArrowDown', 'Home', 'End', 'Tab'
                    ];
                    if (!teclasPermitidas.includes(e.key) && !e.ctrlKey && !e.metaKey) {
                        e.preventDefault();
                    }
                }

            }).on('keyup', function() {
                let mensaje = $(this).val();
                let texto   = mensaje.trim();

                // Contador
                $("#count_letras").text(texto.length);

                // Preview
                mensaje = texto.length == 0 ? '...' : texto;
                mensaje = mensaje.replace(/\n/g, '<br>');
                $("#preview_message_wp").html(reemplazar_variables(mensaje) + mensaje_visto_html);

                // Sincroniza botones de variables
                $('.btn_add_variable').each(function() {
                    let variable = $(this).data('valor');
                    $(this).toggleClass('active', texto.includes(variable));
                });

                guardar_cambios_plantila($(".template-list").find('.active').data('id'));
            });

            //  CUADO CAMBIAN NOMBRE O CLAVE
            $(".input_change").on('keyup',function(){
                guardar_cambios_plantila($(".template-list").find('.active').data('id'));
            });

            //  EVENTO PARA DESHACER LOS CAMBIOS DE LA PLANTILLA MOSTRADA
            $("#btnDeshacer").on('click',async function(){
                const respuesta = await window.modalConfirm('¿Deseas deshacer TODOS los cambios?');

                if (respuesta){
                    let id_plantilla_activa = $(".template-list").find('.active').data('id');
                    obj_plantillas_finales[id_plantilla_activa] = JSON.parse(JSON.stringify(obj_plantillas_originales[id_plantilla_activa]));

                    show_info_plantilla();
                    
                }
            });

            $('.main_content').on('scroll', function() {
                let scrollTop = $(this).scrollTop();
                $('.col-preview').css('transform', `translateY(${scrollTop}px)`);
            });

            //  CLIC PARA INSERTAR VARIABLE
            $('.editor-section').on('click', '.btn_add_variable', function() {
                let variable  = $(this).data('valor');
                let $textarea = $("#textarea_mensaje");
                let $btn      = $(this);

                if ($textarea.val().includes(variable)) {
                    // Si ya existe → la elimina del texto
                    let regex = new RegExp(variable.replace(/[{}]/g, '\\$&'), 'g');
                    $textarea.val($textarea.val().replace(regex, ''));
                    $btn.removeClass('active');
                } else {
                    // Si no existe → la inserta donde está el cursor
                    let textarea   = $textarea[0];
                    let inicio     = textarea.selectionStart;
                    let fin        = textarea.selectionEnd;
                    let texto      = $textarea.val();
                    let nuevoTexto = texto.substring(0, inicio) + variable + texto.substring(fin);

                    $textarea.val(nuevoTexto);

                    let nuevaPosicion = inicio + variable.length;
                    textarea.selectionStart = nuevaPosicion;
                    textarea.selectionEnd   = nuevaPosicion;

                    $btn.addClass('active');
                }

                $textarea.focus();
                $textarea.trigger('keyup');
            });

            //  EMOJIS
            $("#btn_emoji").on('click', function(e) {
                e.stopPropagation();
                $('#emoji_picker_container').toggle();
            });

            $(document).on('emoji-click', 'emoji-picker', function(e) {
                let emoji     = e.originalEvent.detail.unicode;
                let $textarea = $("#textarea_mensaje");
                let textarea  = $textarea[0];

                let inicio     = textarea.selectionStart;
                let fin        = textarea.selectionEnd;
                let texto      = $textarea.val();
                let nuevoTexto = texto.substring(0, inicio) + emoji + texto.substring(fin);

                $textarea.val(nuevoTexto);

                let nuevaPosicion = inicio + emoji.length;
                textarea.selectionStart = nuevaPosicion;
                textarea.selectionEnd   = nuevaPosicion;

                $textarea.focus();
                $textarea.trigger('keyup');

                $('#emoji_picker_container').hide();
            });

            $(document).on('click', function(e) {
                if (!$(e.target).closest('#emoji_picker_container, #btn_emoji').length) {
                    $('#emoji_picker_container').hide();
                }
            });

            //  EVENTO PARA GUARDAR
            $("#btnSave").on('click',async function(){
                let btn =  $(this);
                $(btn).prop('disable',true);

                const form = $('#form_modal_data')[0]; // Obtén el elemento DOM
                let flag_error  = false;
                if (form.checkValidity() === false) {
                    $(form).addClass('was-validated');
                    flag_error  = true;
                } else {
                    $(form).removeClass('was-validated');
                }

                if (flag_error){
                    $(btn).prop('disable',false);
                    return false;
                }

                let id_plantilla_activa = $(".template-list").find('.active').data('id');
                const respuesta         = await window.modalConfirm('¿Deseas continuar con la captura de datos?');

                if (respuesta){
                    $.ajax({
                        url         : url_save,
                        method      : 'post',
                        dataType    : 'json',
                        data        : {
                            accion          : 'save_plantilla',
                            info_plantilla  : obj_plantillas_finales[id_plantilla_activa]
                        },
                        success     : function(data){
                            showAlert('success','Captura exitosa!');

                            show_plantillas_after_save(data);
                            $(btn).prop('disable',false);
                        },
                        error       : function(error){
                            actionJsonError(error,btn);
                        }
                    });
                }
            });

            $("#btnDelete").on('click', async function(){
                let btn                 = $(this);
                let id_plantilla_activa = $(".template-list").find('.active').data('id');
                const respuesta         = await window.modalConfirm('¿Deseas continuar con el borrado de esta plantilla?');

                console.log('id_plantilla_activa',id_plantilla_activa);
                if (respuesta){
                    $.ajax({
                        url         : url_delete,
                        method      : 'post',
                        dataType    : 'json',
                        data        : {
                            id_plantilla    : id_plantilla_activa,
                            clave           : obj_plantillas_originales[id_plantilla_activa]['clave']
                        },
                        success     : function(data){
                            showAlert('success','Borrado exitoso!');

                            show_plantillas_after_save(data);
                            $(btn).prop('disable',false);
                        },
                        error       : function(error){
                            actionJsonError(error,btn);
                        }
                    });
                }
            });
        });// FIN DOCUMENT READY

        //  FUNCIONES
        //  FUNCION PARA MOSTRAR PREVIEW CON INFORMACION
        function reemplazar_variables(mensaje) {

            let dias_semana = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
            let meses       = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

            let hoy         = new Date();
            let manana      = new Date();
            let ayer        = new Date();

            manana.setDate(hoy.getDate() + 1);
            ayer.setDate(hoy.getDate() - 1);

            let reemplazos_preview = {
                '{{PACIENTE}}'       : 'Ismael Pérez',
                '{{PROFESIONAL}}'    : 'Dr. Juan García',
                '{{FECHA_CITA}}'     : `${manana.getDate()} de ${meses[manana.getMonth()]} ${manana.getFullYear()}`,
                '{{HORA}}'           : '14:20',
                '{{FECHA_ANTERIOR}}' : `${ayer.getDate()} de ${meses[ayer.getMonth()]} ${ayer.getFullYear()}`,
                '{{LOCACION}}'       : nombre_locacion,
                '{{MAPS_URL}}'       : 'https://maps.google.com/?q='+latitud_locacion+','+longitud_locacion,
                '{{DIA_CITA}}'       : dias_semana[manana.getDay()],
                '{{DIA_ANTERIOR}}'   : dias_semana[ayer.getDay()]
            };

            $.each(reemplazos_preview, function(variable, valor) {
                mensaje = mensaje.split(variable).join(valor);
            });
            return mensaje;
        }

        //  FUNCION PARA GUARDAR EN EL OBJETO FINAL LA INFORMACION ACTUAL
        //  ESTO PARA QUE AL CAMBIAR ENTRE PLANTILLAS EL AVANCE NO SE PIERDA
        function guardar_cambios_plantila(id_plantilla_activa){
            let mensaje = $("#textarea_mensaje").val().trim();

            obj_plantillas_finales[id_plantilla_activa]['clave']    = $("#input_clave").val().trim();
            obj_plantillas_finales[id_plantilla_activa]['nombre']   = $("#input_nombre").val().trim();
            obj_plantillas_finales[id_plantilla_activa]['tipo_mensaje'] = $("#select_tipo_mensaje").val();
            obj_plantillas_finales[id_plantilla_activa]['mensaje']      = mensaje.replace(/\n/g, '%0A');

            //  ACTUALIZA EL MENU DE LA IZQUIERDA
            $(".template-list").find('.active').find('.clave_plantilla').text($("#input_clave").val().trim() == '' ? 'NUEVA_PLANTILLA' : $("#input_clave").val().trim());
            $(".template-list").find('.active').find('.nombre_plantilla').text($("#input_nombre").val().trim() == '' ? 'Nueva plantilla' : $("#input_nombre").val().trim());
            
            let mensajeCorto = mensaje.replace(/\n/g, ' ');
            mensajeCorto     = mensajeCorto.length > 30 ? mensajeCorto.substring(0, 30) + '...' : mensajeCorto;

            mensajeCorto    = mensajeCorto == '' ? '...' : mensajeCorto;
            $(".template-list").find('.active').find('.mensaje').text(mensajeCorto);
        }

        //  LLENA LA INFORMACION DE LA PLANTILLA EN LOS INPUT Y EN EL PREVIEW
        function show_info_plantilla(){
            let id_plantilla_activa = $(".template-list").find('.active').data('id');

            $("#input_clave").val(obj_plantillas_finales[id_plantilla_activa]['clave']);
            $("#input_nombre").val(obj_plantillas_finales[id_plantilla_activa]['nombre']);
            $("#select_tipo_mensaje").val(obj_plantillas_finales[id_plantilla_activa]['tipo_mensaje'] === null ? '-1' : obj_plantillas_finales[id_plantilla_activa]['tipo_mensaje']);
            let mensaje = obj_plantillas_finales[id_plantilla_activa]['mensaje'];
            mensaje     = mensaje = mensaje.replace(/%0A/g, '\n');
            $("#textarea_mensaje").val(mensaje).trigger('keyup');
        }

        // SE DESTRUYE TODO Y SE RECREA CON LA INFORMACION OBTENIDA DE LA PLANTILLA
        function show_plantillas_after_save(info_plantilla){
            //  SE BLANQUEAN TODOS LOS REGISTROS
            $("#input_clave").val('');
            $("#input_nombre").val('');
            $("#select_tipo_mensaje").val('');
            $("#textarea_mensaje").val('');

            //  SE BORRAN TODOS LAS PLANTILLAS DEL MENU
            $("#div_header_row_plantillas").find('.active').removeClass('active');
            $("#div_header_row_plantillas").find('.template-item').each(function(){
                if ($(this).attr('id') == 'plantilla_0'){
                    return true;
                }

                $(this).remove();
            });

            obj_plantillas_originales   = {
                0   : {
                    activa  : 1,
                    clave   : '',
                    id      : null,
                    mensaje : '',
                    nombre  : '',
                    tipo_mensaje    : ''
                }
            };

            obj_plantillas_finales  = {
                0   : {
                    activa  : 1,
                    clave   : '',
                    id      : null,
                    mensaje : '',
                    nombre  : '',
                    tipo_mensaje    : ''
                }
            };

            //  SE CREAN LOS OBJETOS PARA TENER UNO CON LA INFORMACION ORIGINAL 
            //  Y UN SEGUNDO CON LA INFORMACION EDITADA PARA GUARDAR
            Object.values(info_plantilla).forEach(function(plantilla) {
                obj_plantillas_originales[plantilla.id] = JSON.parse(JSON.stringify(plantilla));
                obj_plantillas_finales[plantilla.id]    = JSON.parse(JSON.stringify(plantilla));

                let mensajeCorto = plantilla['mensaje'].replace(/%0A/g, ' ');
                mensajeCorto     = mensajeCorto.length > 30 ? mensajeCorto.substring(0, 30) + '...' : mensajeCorto;

                mensajeCorto    = mensajeCorto == '' ? '...' : mensajeCorto;
                let row_plantilla   = $("#template_plantilla_menu").clone().removeAttr('id').attr('id','plantilla_'+plantilla.id).data('id',plantilla.id).show();
                $(row_plantilla).find('.clave_plantilla').text(plantilla.clave);
                $(row_plantilla).find('.nombre_plantilla').text(plantilla.nombre);
                $(row_plantilla).find('.mensaje').text(mensajeCorto);
                
                $("#div_header_row_plantillas").append(row_plantilla);
            });

            setTimeout(() => {
                $("#plantilla_0").addClass('active').trigger('click');
            }, 150);
        }
    })();
</script>