<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>Módulo de Caja - Control de Citas</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>

  <style>
    /* ── Base ── */
    body {
      background-color: #f8fafc;
      overflow: hidden;
      height: 100vh;
    }

    /* ── Main layout ── */
    .main-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    .main-content {
      flex: 1;
      overflow-y: auto;
      background-color: #f1f5f9;
      padding: 2rem;
    }

    /* ── Status badges ── */
    .badge-active  { background-color: #dcfce7; color: #166534; }
    .badge-pending { background-color: #fef9c3; color: #854d0e; }

    /* ── Payment method buttons ── */
    .pay-method-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 0.5rem;
      border: 2px solid #e2e8f0;
      border-radius: 0.5rem;
      background: #fff;
      color: #4b5563;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
      transition: border-color 0.15s, background 0.15s, color 0.15s;
    }
    .pay-method-btn:hover  { border-color: #a5b4fc; }
    .pay-method-btn.active { border-color: #6366f1; background: #eef2ff; color: #4338ca; }
    .pay-method-btn.dashed { border-style: dashed; }
    .pay-method-btn i      { font-size: 1.25rem; margin-bottom: 4px; }

    /* ── Partial payment box ── */
    .payment-entry-box {
      background-color: #eef2ff;
      border: 1px solid #c7d2fe;
      border-radius: 0.5rem;
      padding: 1rem;
    }
    .payment-entry-box .input-prefix {
      position: absolute;
      left: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      color: #6366f1;
      font-weight: 700;
      font-size: 1.1rem;
      pointer-events: none;
    }
    .payment-entry-box input {
      padding-left: 1.75rem;
      font-size: 1.25rem;
      font-weight: 700;
      color: #4338ca;
      border: 2px solid #a5b4fc;
      border-radius: 0.5rem;
    }
    .payment-entry-box input:focus {
      border-color: #6366f1;
      box-shadow: 0 0 0 0.2rem rgba(99,102,241,.25);
      outline: none;
    }

    /* ── Process button ── */
    .btn-process {
      background-color: #4f46e5;
      color: #fff;
      border: none;
      border-radius: 0.75rem;
      padding: 1rem;
      font-size: 1.1rem;
      font-weight: 700;
      width: 100%;
      box-shadow: 0 10px 15px -3px rgba(99,102,241,.25);
      transition: background-color 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
    .btn-process:hover { background-color: #4338ca; color: #fff; }

    /* ── Modal ── */
    .modal-footer-summary { background-color: #f8fafc; }
    .focus-ring-indigo:focus { border-color: #6366f1; box-shadow: 0 0 0 0.2rem rgba(99,102,241,.25); }

    /* ── Misc ── */
    .text-indigo { color: #4f46e5; }
    .btn-indigo  { background-color: #4f46e5; color: #fff; border: none; }
    .btn-indigo:hover { background-color: #4338ca; color: #fff; }
  </style>
</head>
<body class="d-flex">

  <!-- ══════════════════════════════════════════
       MODAL — Dividir Pago (Bootstrap nativo)
  ══════════════════════════════════════════ -->
  <div class="modal fade" id="modalDividirPago" tabindex="-1" aria-labelledby="modalDividirPagoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:520px;">
      <div class="modal-content rounded-3 shadow-lg">

        <!-- Modal Header -->
        <div class="modal-header border-bottom px-4 py-3">
          <h5 class="modal-title fw-bold text-dark" id="modalDividirPagoLabel">Dividir Pago</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>

        <!-- Modal Body -->
        <div class="modal-body p-4">

          <!-- Payment methods list -->
          <div class="d-flex flex-column gap-3">

            <!-- Method 1 -->
            <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border">
              <div class="flex-grow-1">
                <label class="form-label fw-bold text-secondary text-uppercase mb-1" style="font-size:.7rem;letter-spacing:.05em;">Método</label>
                <div class="fw-semibold text-dark">Efectivo</div>
              </div>
              <div style="width:8rem;">
                <label class="form-label fw-bold text-secondary text-uppercase mb-1" style="font-size:.7rem;letter-spacing:.05em;">Monto</label>
                <div class="input-group input-group-sm">
                  <span class="input-group-text text-secondary">$</span>
                  <input type="text" class="form-control fw-medium focus-ring-indigo" value="300.00"/>
                </div>
              </div>
              <button class="btn btn-sm btn-light border-0 mt-4 p-1 text-secondary" style="transition:color .15s" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color=''">
                <i class="bi bi-trash3 fs-5"></i>
              </button>
            </div>

            <!-- Method 2 -->
            <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border">
              <div class="flex-grow-1">
                <label class="form-label fw-bold text-secondary text-uppercase mb-1" style="font-size:.7rem;letter-spacing:.05em;">Método</label>
                <div class="fw-semibold text-dark">Tarjeta de Crédito</div>
              </div>
              <div style="width:8rem;">
                <label class="form-label fw-bold text-secondary text-uppercase mb-1" style="font-size:.7rem;letter-spacing:.05em;">Monto</label>
                <div class="input-group input-group-sm">
                  <span class="input-group-text text-secondary">$</span>
                  <input type="text" class="form-control fw-medium focus-ring-indigo" value="300.00"/>
                </div>
              </div>
              <button class="btn btn-sm btn-light border-0 mt-4 p-1 text-secondary" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color=''">
                <i class="bi bi-trash3 fs-5"></i>
              </button>
            </div>

          </div><!-- /payment-methods-list -->

          <!-- Add method button -->
          <button class="btn btn-sm btn-link text-indigo fw-semibold ps-0 mt-3 text-decoration-none d-flex align-items-center gap-1">
            <i class="bi bi-plus-circle fs-5"></i>
            Añadir otro método de pago
          </button>

        </div><!-- /Modal Body -->

        <!-- Modal Footer / Summary -->
        <div class="modal-footer flex-column align-items-stretch px-4 py-4 border-top modal-footer-summary">

          <!-- Totals -->
          <div class="d-flex flex-column gap-2 mb-3 w-100">
            <div class="d-flex justify-content-between align-items-center">
              <span class="small text-secondary">Monto total ingresado:</span>
              <span class="fw-bold text-dark">$600.00</span>
            </div>
            <div class="d-flex justify-content-between align-items-center p-2 rounded border" style="background:#f0fdf4;border-color:#bbf7d0!important;">
              <span class="small fw-medium" style="color:#15803d;">Monto faltante:</span>
              <span class="fw-bold" style="color:#15803d;">$0.00</span>
            </div>
          </div>

          <!-- Actions -->
          <div class="d-flex justify-content-end gap-2 w-100">
            <button type="button" class="btn btn-outline-secondary fw-semibold px-4" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" class="btn btn-indigo fw-semibold px-4">Confirmar Métodos</button>
          </div>

        </div><!-- /Modal Footer -->

      </div><!-- /modal-content -->
    </div><!-- /modal-dialog -->
  </div><!-- /modal -->


  <!-- ══════════════════════════════════════════
       MAIN CONTENT
  ══════════════════════════════════════════ -->
  <main class="main-wrapper flex-grow-1">

    <!-- Body -->
    <div class="main-content">

      <!-- Patient Search -->
      <section class="bg-white p-4 rounded-3 shadow-sm mb-4">
        <h2 class="h6 fw-semibold text-secondary mb-3">Búsqueda de Paciente</h2>
        <div class="d-flex gap-3">
          <div class="flex-grow-1 position-relative">
            <span class="position-absolute top-50 translate-middle-y ps-3" style="left:0;pointer-events:none;">
              <i class="bi bi-search text-secondary"></i>
            </span>
            <input type="text"
                   class="form-control ps-5"
                   placeholder="Buscar por nombre o ID del paciente (ej. Acosta Carrillo)..."/>
          </div>
          <button class="btn btn-indigo px-4 fw-medium">Buscar</button>
        </div>
      </section>

      <!-- Grid: Table + Summary -->
      <div class="row g-4 pb-4">

        <!-- Appointments Table -->
        <div class="col-12 col-xl-8">
          <section class="bg-white rounded-3 shadow-sm h-100">
            <div class="p-3 border-bottom">
              <h2 class="h6 fw-semibold text-secondary mb-0">Citas Pendientes de Pago</h2>
            </div>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0" id="appointments-table">
                <thead class="table-light">
                  <tr>
                    <th scope="col" style="width:2.5rem;">
                      <input class="form-check-input" type="checkbox"/>
                    </th>
                    <th scope="col" class="text-uppercase small fw-bold text-secondary" style="letter-spacing:.05em;">Paciente</th>
                    <th scope="col" class="text-uppercase small fw-bold text-secondary" style="letter-spacing:.05em;">Profesional</th>
                    <th scope="col" class="text-uppercase small fw-bold text-secondary" style="letter-spacing:.05em;">Servicio / Costo</th>
                    <th scope="col" class="text-uppercase small fw-bold text-secondary" style="letter-spacing:.05em;">Fecha y Hora</th>
                    <th scope="col" class="text-uppercase small fw-bold text-secondary" style="letter-spacing:.05em;">Estatus</th>
                  </tr>
                </thead>
                <tbody>
                  <!-- Row 1 -->
                  <tr class="table-active">
                    <td><input class="form-check-input" type="checkbox" checked/></td>
                    <td class="fw-medium small">Acosta Carrillo Iker (16.01)</td>
                    <td class="text-secondary small">Martinez Lenguaje</td>
                    <td class="text-secondary small">PSI / $300</td>
                    <td class="text-secondary small">09/03/2026 09:00 a 09:40</td>
                    <td><span class="badge rounded-pill badge-active px-2 py-1 small fw-semibold">ACTIVA</span></td>
                  </tr>
                  <!-- Row 2 -->
                  <tr class="table-active">
                    <td><input class="form-check-input" type="checkbox" checked/></td>
                    <td class="fw-medium small">Acosta Carrillo Iker (16.01)</td>
                    <td class="text-secondary small">Martinez Lenguaje</td>
                    <td class="text-secondary small">PSI / $300</td>
                    <td class="text-secondary small">09/03/2026 09:45 a 10:25</td>
                    <td><span class="badge rounded-pill badge-active px-2 py-1 small fw-semibold">ACTIVA</span></td>
                  </tr>
                  <!-- Row 3 -->
                  <tr>
                    <td><input class="form-check-input" type="checkbox"/></td>
                    <td class="fw-medium small">Acosta Carrillo Iker (16.01)</td>
                    <td class="text-secondary small">Martinez Lenguaje</td>
                    <td class="text-secondary small">PSI / $300</td>
                    <td class="text-secondary small">09/03/2026 10:30 a 11:10</td>
                    <td><span class="badge rounded-pill badge-active px-2 py-1 small fw-semibold">ACTIVA</span></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>
        </div>

        <!-- Payment Summary -->
        <div class="col-12 col-xl-4">
          <section class="bg-white rounded-3 shadow-sm p-4">

            <h2 class="h6 fw-semibold text-secondary mb-4 pb-2 border-bottom">Resumen de Pago</h2>

            <!-- Line items -->
            <div class="d-flex flex-column gap-3 mb-4">
              <div class="d-flex justify-content-between text-secondary small">
                <span>Subtotal (2 citas)</span>
                <span class="fw-medium">$600.00</span>
              </div>
              <div class="d-flex justify-content-between text-secondary small">
                <span>Impuestos (0%)</span>
                <span class="fw-medium">$0.00</span>
              </div>
              <div class="d-flex justify-content-between text-secondary small">
                <span>Descuentos</span>
                <span class="fw-medium text-success">-$0.00</span>
              </div>
              <div class="d-flex justify-content-between pt-3 border-top align-items-center">
                <span class="h6 fw-bold text-dark mb-0">Total a Pagar</span>
                <span class="h5 fw-bold mb-0 text-indigo" id="total-amount">$600.00</span>
              </div>
            </div>

            <!-- Partial Payment Input -->
            <div class="payment-entry-box mb-4">
              <label for="amount-to-pay" class="form-label fw-bold text-uppercase small mb-2"
                     style="color:#1e1b4b;letter-spacing:.05em;">
                Cantidad a Pagar / Recibir
              </label>
              <div class="position-relative">
                <span class="input-prefix">$</span>
                <input type="number"
                       id="amount-to-pay"
                       class="form-control"
                       placeholder="0.00"
                       value="600.00"/>
              </div>
              <div class="d-flex justify-content-between align-items-center mt-2 small">
                <span class="text-secondary">Saldo Restante:</span>
                <span class="fw-bold text-danger" id="remaining-balance">$0.00</span>
              </div>
            </div>

            <!-- Payment method selector -->
            <div class="mb-4">
              <label class="form-label small fw-medium text-dark">Método de Pago para este monto</label>

              <div class="row g-2 mb-2">
                <div class="col-6">
                  <button class="pay-method-btn active">
                    <i class="bi bi-wallet2"></i>
                    Efectivo
                  </button>
                </div>
                <div class="col-6">
                  <button class="pay-method-btn">
                    <i class="bi bi-credit-card"></i>
                    Tarjeta
                  </button>
                </div>
              </div>

              <div class="row g-2">
                <div class="col-6">
                  <button class="pay-method-btn">
                    <i class="bi bi-arrow-left-right"></i>
                    Transfer.
                  </button>
                </div>
                <div class="col-6">
                  <button class="pay-method-btn dashed"
                          data-bs-toggle="modal" data-bs-target="#modalDividirPago">
                    <i class="bi bi-sliders"></i>
                    Dividir Pago
                  </button>
                </div>
              </div>
            </div>

            <!-- Process button -->
            <button class="btn-process">
              <i class="bi bi-check-circle fs-5"></i>
              Procesar Pago
            </button>

            <p class="text-center text-muted small fst-italic mt-3 mb-0">
              Se enviará el comprobante de pago al correo registrado del paciente.
            </p>

          </section>
        </div>

      </div><!-- /row -->
    </div><!-- /main-content -->
  </main>

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>