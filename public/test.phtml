                </div>
                <h1 style="font-size:2rem;font-weight:700;letter-spacing:-0.02em;color:var(--primary);margin:0;">
                    Asignación de Becas
                </h1>
            </div>
            <div class="d-flex gap-3">
                <button class="btn-outline-primary-custom">Exportar Reporte</button>
                <button class="btn-primary-custom">Nueva Beca</button>
