<main id="main">
    <div class="p-4">

        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <div class="d-flex align-items-center gap-1 mb-2">
                    <a href="#" class="breadcrumb-link">Caja</a>
                    <span class="material-symbols-outlined breadcrumb-sep" style="font-size:14px;">chevron_right</span>
