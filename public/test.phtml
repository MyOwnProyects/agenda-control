        </div>

        <!-- ── Patient + Scholarship Selector ── -->
        <div class="card-custom p-4 mb-4">
            <div class="row g-4">
                <div class="col-12 col-md-6">
                    <label class="label-bold">PACIENTE</label>
                    <div class="input-icon-wrap">
                        <span class="material-symbols-outlined input-icon">person</span>
                        <input class="input-custom" type="text" value="Javier Alejandro Montes">
                    </div>
                    <p style="font-size:0.6875rem;margin-top:4px;color:rgba(73,68,83,0.7);font-style:italic;padding:0 4px;">
                        ID: 10294857 - Estado: Activo
                    </p>
                </div>
                <div class="col-12 col-md-6">
                    <label class="label-bold">BECA</label>
                    <select class="select-custom">
                        <option>Beca Excelencia Académica - 100%</option>
                        <option selected>Beca Socioeconómica Especial - 50%</option>
                        <option>Convenio Empresa Aliada</option>
