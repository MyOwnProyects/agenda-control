<div id="sticky-footer">
    <div class="d-flex gap-5">
        <div class="footer-stat">
            <span class="stat-label">Total a Liquidar</span>
            <span class="stat-value-secondary">$1,500.00</span>
        </div>
        <div class="footer-stat">
            <span class="stat-label">Saldo Remanente</span>
            <span class="stat-value-primary">$500.00</span>
        </div>
    </div>
    <div class="d-flex gap-3">
        <button class="btn-cancel">Cancelar</button>
        <button class="btn-confirm" onclick="simulateConfirm(event)">
            <span class="material-symbols-outlined" style="font-size:20px;">check_circle</span>
            Confirmar Asignación
        </button>
    </div>
</div>

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function simulateConfirm(e) {
        const btn = e.currentTarget;
        const original = btn.innerHTML;
        btn.innerHTML = '<span class="material-symbols-outlined spin">sync</span> Procesando...';
        btn.disabled = true;

        setTimeout(() => {
            btn.style.backgroundColor = '#16a34a';
            btn.innerHTML = '<span class="material-symbols-outlined">check</span> ¡Asignada!';

            setTimeout(() => {
                btn.innerHTML = original;
                btn.style.backgroundColor = '';
                btn.disabled = false;
                alert('La beca ha sido asignada exitosamente a los conceptos seleccionados.');
            }, 2000);
        }, 1500);
    }

    // Toggle checkbox on row click
    document.querySelectorAll('tbody tr').forEach(row => {
        row.addEventListener('click', () => {
            const cb = row.querySelector('input[type="checkbox"]');
            if (cb) cb.checked = !cb.checked;
        });
    });
</script>

